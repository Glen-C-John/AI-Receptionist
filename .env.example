 # Application
APP_NAME=AI Receptionist
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000
DOMAIN=your-ngrok-url.ngrok-free.app
# Remove "https://" from the start, just keep the domain part,do either ngrok or tailscale
DOMAIN=your-machine-name.tailnet-name.ts.net. #gemini

# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_key

# AI Services
GROQ_API_KEY=your_groq_key
DEEPSEEK_API_KEY=your_deepseek_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1 #gemini
CARTESIA_API_KEY=your_cartesia_key


# Twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Google Calendar
GOOGLE_CREDENTIALS_PATH=google_credentials.json
GOOGLE_CALENDAR_ID=primary

# Business Configuration
BUSINESS_NAME=Hercules Detailing
BUSINESS_TIMEZONE=America/Chicago
APPOINTMENT_DURATION_MINUTES=60
BUSINESS_HOURS_START=09:00
BUSINESS_HOURS_END=18:00

# Voice Agent Configuration
AGENT_NAME=Kylie
AGENT_VOICE=female-1
AGENT_SPEED=1.1
AGENT_VOICE_ID=79a125e8-cd45-4c13-8a67-188112f4dd22 #gemini
STT_MODEL=whisper-large-v3
LLM_MODEL=deepseek-chat
TTS_MODEL=sonic-english

# Security
API_SECRET_KEY=your_secret_key_here_generate_with_openssl
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
MAX_CALL_DURATION_MINUTES=10